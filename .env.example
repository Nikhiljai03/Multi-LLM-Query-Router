# Application
APP_NAME=AI Query Router
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=query_events

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_router
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================
# 🚀 GROQ MODELS (Primary - FREE & FAST)
# ============================================
# Get free API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
USE_GROQ=True

# 3-Tier Model Configuration
GROQ_SIMPLE_MODEL=llama-3.1-8b-instant           # 8B - Ultra fast (560 T/s)
GROQ_MEDIUM_MODEL=llama-3.3-70b-versatile        # 70B - Balanced (280 T/s)
GROQ_COMPLEX_MODEL=openai/gpt-oss-120b           # 120B - Best quality (500 T/s)

# ============================================
# 🔄 TOGETHER AI MODELS (Fallback - FREE)
# ============================================
# Get free API key from: https://api.together.xyz/
TOGETHER_API_KEY=your_together_api_key_here
USE_TOGETHER_AS_FALLBACK=True

# 3-Tier Fallback Configuration
TOGETHER_SIMPLE_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo      # 3B - Very fast
TOGETHER_MEDIUM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo # 8B - Fast
TOGETHER_COMPLEX_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo # 70B - Best

# ============================================
# 🎯 FALLBACK CONFIGURATION
# ============================================
ENABLE_FALLBACK=True

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Model Configuration
SIMPLE_QUERY_MAX_WORDS=10
MEDIUM_QUERY_MAX_WORDS=50
